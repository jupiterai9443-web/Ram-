rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - customerName: string (required, max 100 chars)
    //   - status: string (required, 'pending' or 'completed')
    //   - totalQuantity: number (required, positive)
    //   - createdAt: timestamp (required)
    //   - items: list of objects (required, max 100 items)
    //
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - email: string
    //   - role: string ('admin')
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "jupiterai9443@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'status', 'totalQuantity', 'createdAt', 'items']) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100 &&
             data.status in ['pending', 'completed'] &&
             data.totalQuantity is number && data.totalQuantity > 0 &&
             data.createdAt is timestamp &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100;
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId || isAdmin();
      allow create, update, delete: if false;
    }
  }
}
